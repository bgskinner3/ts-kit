{
  "name": "@bgskinner2/ts-utils",
  "version": "1.0.3",
  "description": "A collection of high-performance TypeScript utilities and React type guards.",
  "author": "Brennan Skinner",
  "license": "ISC",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "ts-patch install",
    "dev": "tsup src/index.ts --format cjs,esm --watch --dts",
    "build": "tsup src/index.ts transformer/index.ts --format cjs,esm --dts --clean",
    "build:deprecated": "tsup src/index.ts --format cjs,esm --dts --clean --minify",
    "test": "jest",
    "cov:test": "jest --coverage",
    "lint": "eslint '**/*.{ts,tsx}' --max-warnings=0",
    "lint:fix": "eslint '**/*.{ts,tsx}' --fix",
    "format": "prettier --write '**/*.{ts,tsx,js,json,md}'",
    "format:check": "prettier --check '**/*.{ts,tsx,js,json,md}'",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "typescript",
    "utils",
    "react",
    "guards"
  ],
  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-test-renderer": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.6.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "ts-patch": "^3.3.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com"
  },
  "bugs": {
    "url": "https://github.com"
  },
  "homepage": "https://github.com"
}
